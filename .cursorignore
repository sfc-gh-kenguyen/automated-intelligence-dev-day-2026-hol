**/profile_staging.json
**/postgres_config.json
**/config.properties
**/credentials.json
**/.env
**/.env.*
*.pem
*.p8
*.pub
*.key
*.ppk

# ============================================================================
# Build artifacts & dependencies — large, no value for AI
# ============================================================================
**/target/
**/node_modules/
**/dbt_packages/
**/dbt_modules/

# ============================================================================
# Virtual environments
# ============================================================================
**/venv/
**/.venv/
**/env/
**/ENV/

# ============================================================================
