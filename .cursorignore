# ============================================================================
**/__pycache__/
**/.ipynb_checkpoints/
**/.pytest_cache/
**/.mypy_cache/
**/.cache/
**/.trulens/

# ============================================================================
# IDE & OS artifacts
# ============================================================================
**/.vscode/
**/.idea/
.DS_Store

# ============================================================================
# Demo output & video (generated at runtime)
# ============================================================================
demo-output/
demo-video/

# ============================================================================
